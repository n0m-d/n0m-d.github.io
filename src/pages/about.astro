        }
        to {
          opacity: 1;
          clip-path: inset(0 0 0 0);
          transform: translateY(0);
        }
      }

      #clearance .clearance-card::after {
        background: linear-gradient(105deg, transparent 40%, rgba(var(--shell-rgb), 0.05) 50%, transparent 60%);
        animation: cardGlint 6s ease-in-out infinite;
      }
      #clearance .clearance-card:hover {
        border-color: rgba(var(--shell-rgb), 0.28);
