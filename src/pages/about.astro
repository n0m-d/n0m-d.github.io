        transform: scaleX(0.35);
        transform-origin: left;
        opacity: 0.35;
        transition: transform 0.4s ease, background 0.3s, opacity 0.3s;
      }
      #clearance .clearance-level span.vault-bar--lit {
        background: rgba(var(--shell-rgb), 0.55);
        opacity: 1;
      }
      #clearance.is-active .clearance-level span.vault-bar--lit {
        animation: vaultBarFill 0.45s ease forwards;
      }
      #clearance.is-active .clearance-card:nth-child(1) .clearance-level span.vault-bar--lit:nth-child(1) { animation-delay: 0.55s; }
      #clearance.is-active .clearance-card:nth-child(1) .clearance-level span.vault-bar--lit:nth-child(2) { animation-delay: 0.65s; }
      #clearance.is-active .clearance-card:nth-child(1) .clearance-level span.vault-bar--lit:nth-child(3) { animation-delay: 0.75s; }
      #clearance.is-active .clearance-card:nth-child(1) .clearance-level span.vault-bar--lit:nth-child(4) { animation-delay: 0.85s; }
      #clearance.is-active .clearance-card:nth-child(2) .clearance-level span.vault-bar--lit:nth-child(1) { animation-delay: 0.75s; }
      #clearance.is-active .clearance-card:nth-child(2) .clearance-level span.vault-bar--lit:nth-child(2) { animation-delay: 0.85s; }
      #clearance.is-active .clearance-card:nth-child(2) .clearance-level span.vault-bar--lit:nth-child(3) { animation-delay: 0.95s; }
      #clearance.is-active .clearance-card:nth-child(2) .clearance-level span.vault-bar--lit:nth-child(4) { animation-delay: 1.05s; }
      #clearance.is-active .clearance-card:nth-child(2) .clearance-level span.vault-bar--lit:nth-child(5) { animation-delay: 1.15s; }
      @keyframes vaultBarFill {
        from { transform: scaleX(0.15); opacity: 0.25; }
        to { transform: scaleX(1); opacity: 1; }
      }
      #clearance .clearance-card:hover .clearance-level span.vault-bar--lit {
        background: var(--shell);
      }

      #clearance .vault-serial {
        font-size: 0.42rem; letter-spacing: 0.14em;
        color: rgba(var(--ghost-rgb), 0.35);
        margin-bottom: 0.65rem;
        font-variant-numeric: tabular-nums;
      }

      #clearance .vault-credentials {
        display: flex; flex-direction: column; gap: 0;
      }
      #clearance .vault-cred {
        display: flex; align-items: baseline;
        flex-wrap: nowrap;
        gap: 0.35rem;
        padding: 0.45rem 0;
        border-bottom: 1px solid rgba(var(--ghost-rgb), 0.06);
        min-width: 0;
        opacity: 0;
      }
      #clearance .vault-cred:last-child { border-bottom: none; padding-bottom: 0; }
      #clearance.is-active .vault-cred {
        animation: vaultCredIn 0.4s ease forwards;
      }
      #clearance.is-active .clearance-card:nth-child(1) .vault-cred:nth-child(1) { animation-delay: 0.95s; }
      #clearance.is-active .clearance-card:nth-child(2) .vault-cred:nth-child(1) { animation-delay: 1.15s; }
      #clearance.is-active .clearance-card:nth-child(2) .vault-cred:nth-child(2) { animation-delay: 1.28s; }
      #clearance.is-active .clearance-card:nth-child(2) .vault-cred:nth-child(3) { animation-delay: 1.41s; }
      @keyframes vaultCredIn {
        from { opacity: 0; transform: translateX(-6px); }
        to { opacity: 1; transform: translateX(0); }
      }

      #clearance .vault-cred__code {
        flex: 0 0 auto;
        font-size: 0.58rem; letter-spacing: 0.1em;
        color: rgba(var(--cyber-rgb), 0.85);
        white-space: nowrap;
      }
      #clearance .vault-cred__dots {
        flex: 1 1 auto;
        min-width: 0.5rem;
        height: 0;
        align-self: flex-end;
        margin-bottom: 0.18rem;
        border-bottom: 1px dotted rgba(var(--ghost-rgb), 0.16);
      }
      #clearance .vault-cred__name {
        flex: 0 1 auto;
        min-width: 0;
        font-size: 0.68rem;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: right;
        line-height: 1.35;
      }
      #clearance .vault-cred__name a {
        color: inherit; text-decoration: none;
        transition: color 0.2s, text-shadow 0.2s;
      }
      #clearance .vault-cred:hover .vault-cred__name,
      #clearance .vault-cred:hover .vault-cred__name a {
        color: var(--ghost);
        text-shadow: 0 0 8px rgba(var(--ghost-rgb), 0.2);
      }

      #clearance .vault-footer {
        margin-top: 1.25rem;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(var(--shell-rgb), 0.08);
        font-size: 0.44rem; letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(var(--ghost-rgb), 0.32);
        text-align: center;
        opacity: 0;
        position: relative; z-index: 1;
      }
      #clearance.is-active .vault-footer {
        animation: vaultCredIn 0.5s ease forwards;
        animation-delay: 1.55s;
      }

      .clearance-card {
        background: rgba(14, 12, 24, 0.55);
        border: 1px solid rgba(var(--shell-rgb), 0.12);
        backdrop-filter: blur(calc(6px + var(--focus) * 3px));
        -webkit-backdrop-filter: blur(calc(6px + var(--focus) * 3px));
        padding: 1.25rem;
        clip-path: polygon(0 8px, 8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%);
        transition: opacity 0.15s, transform 0.15s, border-color 0.3s;
        position: relative;
        overflow: hidden;
      }
      .clearance-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(105deg, transparent 40%, rgba(var(--ghost-rgb), 0.04) 50%, transparent 60%);
        transform: translateX(-100%);
        animation: cardGlint 5s ease-in-out infinite;
      }
      @keyframes cardGlint {
        0%, 70%, 100% { transform: translateX(-100%); }
        85% { transform: translateX(100%); }
      }
      .clearance-card:hover {
        border-color: rgba(var(--ghost-rgb), 0.25);
        transform: translateY(-2px);
      }

      .clearance-org {
        font-size: 0.5rem; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--shell);
        margin-bottom: 0.75rem;
      }
      .clearance-level {
        display: flex; gap: 3px; margin-bottom: 0.85rem;
      }
      .clearance-level span {
        flex: 1; height: 3px;
        background: rgba(var(--ghost-rgb), 0.15);
        transition: background 0.3s, transform 0.3s;
        transform-origin: left;
        animation: levelPulse 2.5s ease-in-out infinite;
      }
      .clearance-level span:nth-child(1) { animation-delay: 0s; }
      .clearance-level span:nth-child(2) { animation-delay: 0.15s; }
      .clearance-level span:nth-child(3) { animation-delay: 0.3s; }
      .clearance-level span:nth-child(4) { animation-delay: 0.45s; }
      .clearance-level span:nth-child(5) { animation-delay: 0.6s; }
      @keyframes levelPulse {
        0%, 100% { transform: scaleX(1); opacity: 0.5; }
        50% { transform: scaleX(1); opacity: 1; background: rgba(var(--ghost-rgb), 0.4); }
      }
      .clearance-card:hover .clearance-level span:nth-child(-n+3) { background: var(--ghost); opacity: 1; }

      .clearance-item {
        font-size: 0.72rem; color: var(--text);
        padding: 0.35rem 0;
        border-bottom: 1px solid rgba(var(--ghost-rgb), 0.06);
      }
      .clearance-item:last-child { border-bottom: none; }
      .clearance-item a {
        color: inherit; text-decoration: none;
        transition: color 0.2s;
      }
      .clearance-item a:hover { color: var(--ghost); }

      .vector-tags {
        display: flex; flex-wrap: wrap; gap: 0.5rem;
        margin-top: 1rem;
      }
      .vector-tag {
        font-size: 0.52rem; letter-spacing: 0.08em;
        padding: 0.3rem 0.65rem;
        border: 1px solid rgba(var(--ghost-rgb), 0.2);
        color: var(--ghost-dim);
        clip-path: polygon(4px 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0 100%, 0 4px);
        transition: opacity 0.15s, transform 0.15s, color 0.2s, border-color 0.2s;
        animation: netTagPulse 4s ease-in-out infinite;
      }
      .vector-tags .vector-tag:nth-child(1) { animation-delay: 0s; }
      .vector-tags .vector-tag:nth-child(2) { animation-delay: 0.4s; }
      .vector-tags .vector-tag:nth-child(3) { animation-delay: 0.8s; }
      .vector-tags .vector-tag:nth-child(4) { animation-delay: 1.2s; }
      .vector-tags .vector-tag:nth-child(5) { animation-delay: 1.6s; }
      @keyframes netTagPulse {
        0%, 100% { border-color: rgba(var(--ghost-rgb), 0.2); box-shadow: none; }
        50% { border-color: rgba(var(--cyber-rgb), 0.3); box-shadow: 0 0 10px hsla(var(--hue), 25%, 50%, 0.08); }
      }
      .vector-tag:hover {
        color: var(--ghost);
        border-color: rgba(var(--ghost-rgb), 0.45);
      }

      .egress-title {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        font-weight: 700;
        color: var(--ghost);
        margin-bottom: 1rem;
        letter-spacing: 0.05em;
        animation: jackOut 4s ease-in-out infinite;
      }
      @keyframes jackOut {
        0%, 100% { text-shadow: 0 0 0 transparent; opacity: 0.85; }
        50% { text-shadow: 0 0 20px hsla(var(--hue), 35%, 55%, 0.25); opacity: 1; }
      }

      .btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 1.5rem; }

      .btn {
        font-family: var(--font);
        font-size: 0.6rem; font-weight: 700;
        letter-spacing: 0.12em; text-transform: uppercase;
        padding: 0.85rem 1.75rem;
        text-decoration: none;
        transition: all 0.3s;
        clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
      }
      .btn--ghost {
        background: transparent;
        border: 1px solid var(--ghost);
        color: var(--ghost);
      }
      .btn--ghost:hover { background: rgba(var(--wire-rgb), 0.06); box-shadow: var(--glow-wire); }
      .btn--shell {
        background: linear-gradient(135deg, var(--magenta), var(--violet), var(--cyber));
        border: 1px solid transparent;
        color: var(--deep);
      }
      .btn--shell:hover { filter: brightness(1.15); transform: translateY(-1px); box-shadow: 0 0 24px hsla(var(--hue), 90%, 55%, 0.35); }

      footer {
        position: relative; z-index: 10;
        padding: 1.5rem 2.5rem;
        border-top: 1px solid var(--border);
        display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
        font-size: 0.48rem; letter-spacing: 0.12em; color: var(--text-dim);
      }
      footer a { color: var(--text-dim); text-decoration: none; }
      footer a:hover { color: var(--ghost); }

      @media (max-width: 768px) {
        nav { padding: 1rem 1.25rem; }
        .nav-links { display: none; }
        .sector { padding: 5rem 1.25rem; }
        .dossier-grid { grid-template-columns: 1fr; }
        #dossier .dossier-grid { grid-template-columns: 1fr; }
        .hud-frame { inset: 0.75rem; }
        .hud-tl, .hud-tr, .hud-bl, .hud-br { font-size: 0.45rem; }
      }

      @media (prefers-reduced-motion: reduce) {
        .sector { --section-reveal: 1; }
        .hero-wrap, .slab-wrap { opacity: 1; transform: none; }
        .sector-tag, .quote { --child-reveal: 1; --child-shift: 0px; opacity: 1; transform: none; }
        .scanlines, .scan-beam, .hex-bg, .hex-bg::before, .hex-bg::after,
        .backdrop, .chroma-bleed, .chroma-bleed::before, .chroma-bleed::after,
        .interference, .synapse-lines, .data-stream, .hud-frame, .boot-ring, .boot-status,
        #scroll-progress, .ghost-title .ghost-word, .ghost-title .ghost-word::before,
        .ice-fall span, .net-mesh, .construct-frame span,
        .slab-scan, .vector-tag, .ghost-title .ghost-word::after, .ghost-title .shell-word, .scroll-cue,
        .nav-brand .void, .egress-title,
        .slab-status, .slab::before, .slab::after, .clearance-card::after,
        .clearance-level span, body::before, body::after,
        #dossier .ice-frame span, #dossier .ice-shimmer, #dossier .ice-link,
        #dossier .stat-val, #dossier .endpoint, #dossier .ice-label,
        #dossier .bio-text, #dossier .vector-tag, #dossier .ice-wave,
        #dossier .ice-hex { animation: none; }
        .hero-wrap, .slab-wrap, .stat-block, .clearance-card, .vector-tag { transition: none !important; }
        #dossier .bio-text, #dossier .ice-label, #dossier .ice-dots, #dossier .vector-tag { opacity: 1; transform: none; filter: none; }
        #dossier.is-active .stat-block { animation: none; opacity: 1; transform: none; clip-path: none; }
        #dossier .ice-wave { opacity: 0.6; transform: scaleX(1); }
        #clearance .vault-shimmer, #clearance .vault-frame span,
        #clearance .vault-stamp, #clearance .vault-stamp__ring,
        #clearance.is-active .clearance-card, #clearance.is-active .vault-cred,
        #clearance.is-active .vault-badge, #clearance.is-active .vault-footer,
        #clearance.is-active .clearance-level span.vault-bar--lit { animation: none; }
        #clearance .vault-badge, #clearance .vault-stamp, #clearance .vault-cred,
        #clearance .vault-footer { opacity: 1; transform: none; }
        #clearance .clearance-card { animation: none; opacity: 1; transform: none; clip-path: none; }
        #clearance .clearance-level span.vault-bar--lit { transform: scaleX(1); opacity: 1; }
        .backdrop { filter: none; transform: none; }
        .ghost-title { transform: none; }
      }
    </style>
  </head>
  <body>
    <div id="boot-screen" class="boot-screen">
