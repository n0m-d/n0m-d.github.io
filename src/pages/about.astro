        -webkit-backdrop-filter: blur(calc(4px + var(--focus) * 2px));
        padding: 1.15rem 1.1rem 1rem;
        clip-path: polygon(0 6px, 6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%);
