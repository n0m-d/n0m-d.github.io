---
// GHOST WIRE — Neuromancer × Ghost in the Shell
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About — v0iid</title>
    <meta
      name="description"
      content="Operator dossier. Application security, CVE analysis, code auditing."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="prefetch" href="/getting-started/introduction/overview/" />
    <link rel="prefetch" href="/" />
    <link rel="prefetch" href="/tools/" />
    <style>
      :root {
        --void: #0a0814;
        --deep: #06040c;
        --wire: #fffaff;
        --wire-dim: #a8a0b8;
        --wire-rgb: 255, 250, 255;
        --ash: #ece0ff;
        --ash-dim: #807890;
        --ash-rgb: 236, 224, 255;
        --cyber: #a8f0ff;
        --cyber-rgb: 168, 240, 255;
        --magenta: #e0a8f0;
        --magenta-rgb: 224, 168, 240;
        --violet: #b8a8e0;
        --violet-rgb: 184, 168, 224;
        --amber: #e8c8a8;
        --lime: #b8e8b8;
        --trace: var(--cyber);
        --ink: #100818;
        --text: #f0ecff;
        --text-dim: #a89cb8;
        --surface: rgba(12, 10, 20, 0.76);
        --border: rgba(var(--violet-rgb), 0.3);
        --glow-wire: 0 0 40px rgba(224, 168, 240, 0.2), 0 0 72px rgba(224, 168, 240, 0.06);
        --glow-ash: 0 0 32px rgba(168, 240, 255, 0.16);
        --glow-cyber: 0 0 40px rgba(184, 168, 224, 0.22);
        --glow-ghost: var(--glow-wire);
        --glow-shell: var(--glow-cyber);
        --ghost: var(--wire);
        --ghost-dim: var(--wire-dim);
        --ghost-rgb: var(--wire-rgb);
        --shell: var(--ash);
        --shell-dim: var(--ash-dim);
        --shell-rgb: var(--ash-rgb);
        --cyan: var(--trace);
        --font: 'JetBrains Mono', monospace;
        --mx: 50%;
        --my: 50%;
        --scroll: 0;
        --reveal: 1;
        --parallax: 0px;
        --dive: 0;
        --vel: 0;
        --hue: 260;
        --bloom: 0.72;
        --focus: 0;
        --bg-blur: 0;
        --pulse: 0.5;
        --scan: 0;
        --tilt: 0deg;
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html {
        scroll-behavior: smooth;
        font-size: 110%;
      }

      @supports (zoom: 1) {
        html {
          font-size: 100%;
          zoom: 1.1;
        }
      }

      body {
        background: var(--void);
        color: var(--text);
        font-family: var(--font);
        overflow-x: hidden;
        cursor: crosshair;
      }

      /* targeting reticle */
      body::before {
        content: '';
        position: fixed;
        width: calc(72px + var(--vel) * 24px);
        height: calc(72px + var(--vel) * 24px);
        left: var(--mx);
        top: var(--my);
        transform: translate(-50%, -50%) rotate(calc(var(--scroll) * 90deg));
        border: 1px solid hsla(var(--hue), 35%, 58%, calc(0.08 + var(--vel) * 0.12));
        border-radius: 50%;
        pointer-events: none;
        z-index: 5;
        opacity: calc(1 - var(--focus) * 0.85);
        transition: left 0.1s ease-out, top 0.1s ease-out, width 0.2s, height 0.2s, opacity 0.6s ease;
        box-shadow: 0 0 8px hsla(var(--hue), 40%, 55%, calc(0.04 + var(--bloom) * 0.08));
      }

      body::after {
        content: '';
        position: fixed;
        width: 14px;
        height: 14px;
        left: var(--mx);
        top: var(--my);
        transform: translate(-50%, -50%);
        background:
          linear-gradient(hsl(calc(var(--hue) + 40), 90%, 70%), hsl(calc(var(--hue) + 40), 90%, 70%)) center/1px 100% no-repeat,
          linear-gradient(hsl(var(--hue), 90%, 65%), hsl(var(--hue), 90%, 65%)) center/100% 1px no-repeat;
        opacity: calc((0.15 + var(--vel) * 0.2) * (1 - var(--focus) * 0.9));
        pointer-events: none;
        z-index: 5;
        transition: left 0.1s ease-out, top 0.1s ease-out, opacity 0.6s ease;
      }

      /* depth-of-field backdrop — blurs when dossier / clearance in focus */
      .backdrop {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        filter: blur(calc(var(--bg-blur) * 1px)) brightness(calc(1.32 - var(--focus) * 0.04));
        transform: scale(calc(1.008 + var(--focus) * 0.012)) translateZ(0);
        transform-origin: center center;
        transition: filter 0.75s cubic-bezier(0.4, 0, 0.2, 1),
          transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .backdrop-veil {
        position: absolute;
        inset: 0;
        background: radial-gradient(
          ellipse at 50% 45%,
          rgba(10, 6, 16, calc(var(--focus) * 0.03)) 0%,
          rgba(10, 6, 16, calc(var(--focus) * 0.14)) 100%
        );
        transition: background 0.75s ease;
      }

      #section9-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

      .noise {
        position: fixed; inset: 0; z-index: 4; pointer-events: none; opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 160px;
      }

      .scanlines {
        position: fixed; inset: 0; z-index: 1; pointer-events: none;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px,
          hsla(var(--hue), 40%, 55%, 0.012) 2px, hsla(var(--hue), 40%, 55%, 0.012) 3px);
        animation: scanDrift 10s linear infinite;
      }

      .scan-beam {
        position: fixed;
        left: 0; right: 0;
        height: 2px;
        z-index: 3;
        pointer-events: none;
        background: linear-gradient(90deg,
          transparent 0%,
          hsla(calc(var(--hue) - 20), 45%, 55%, 0.06) 20%,
          hsla(var(--hue), 50%, 58%, 0.22) 50%,
          hsla(calc(var(--hue) + 30), 45%, 55%, 0.06) 80%,
          transparent 100%);
        box-shadow: 0 0 16px hsla(var(--hue), 45%, 55%, 0.12);
        animation: beamSweep 8s ease-in-out infinite;
        opacity: calc((0.2 + var(--dive) * 0.25) * (1 - var(--focus) * 0.7));
      }

      @keyframes scanDrift {
        from { background-position: 0 0; }
        to { background-position: 0 36px; }
      }

      @keyframes beamSweep {
        0% { top: -2%; opacity: 0; }
        5% { opacity: 0.6; }
        95% { opacity: 0.6; }
        100% { top: 102%; opacity: 0; }
      }

      .vignette {
        position: fixed; inset: 0; z-index: 2; pointer-events: none;
        background:
          radial-gradient(ellipse at 50% 40%, transparent 60%, rgba(0, 0, 0, 0.72) 100%),
          radial-gradient(ellipse at 20% 80%, hsla(280, 90%, 58%, 0.16) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 20%, hsla(190, 100%, 62%, 0.14) 0%, transparent 45%);
      }

      .chroma-bleed {
        position: absolute; inset: 0; pointer-events: none;
        overflow: hidden;
        mix-blend-mode: soft-light;
        opacity: calc(0.2 + var(--bloom) * 0.26);
      }
      .chroma-bleed::before,
      .chroma-bleed::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        animation: blobDrift 18s ease-in-out infinite;
      }
      .chroma-bleed::before {
        width: 40vmax; height: 40vmax;
        left: -8%; top: 25%;
        background: hsla(calc(var(--hue) + 15), 55%, 58%, 0.34);
      }
      .chroma-bleed::after {
        width: 34vmax; height: 34vmax;
        right: -4%; bottom: 15%;
        background: hsla(calc(var(--hue) - 40), 50%, 55%, 0.28);
        animation-delay: -7s;
        animation-direction: reverse;
      }
      @keyframes blobDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(5vw, -4vh) scale(1.08); }
        66% { transform: translate(-4vw, 3vh) scale(0.92); }
      }

      /* HUD corner brackets */
      .hud-frame {
        position: fixed; inset: 1.25rem; z-index: 90; pointer-events: none;
        border: 1px solid transparent;
        transition: opacity 0.3s, transform 0.3s;
        animation: hudPulse 6s ease-in-out infinite;
      }
      @keyframes hudPulse {
        0%, 100% { inset: 1.25rem; transform: rotate(0deg); }
        50% { inset: 1.18rem; transform: rotate(0.25deg); }
      }
      .hex-bg {
        position: absolute; inset: 0; pointer-events: none;
        overflow: hidden;
      }
      .hex-bg::before, .hex-bg::after {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        width: 55vmax; height: 55vmax;
        margin: -27.5vmax 0 0 -27.5vmax;
        border: 1px solid hsla(var(--hue), 30%, 52%, 0.06);
        animation: echoSpin 28s linear infinite;
      }
      .hex-bg::after {
        width: 38vmax; height: 38vmax;
        margin: -19vmax 0 0 -19vmax;
        border-color: hsla(calc(var(--hue) + 50), 35%, 50%, 0.05);
        animation: echoSpin 18s linear infinite reverse;
      }
      @keyframes echoSpin {
        from { transform: rotate(0deg) rotateX(62deg); }
        to { transform: rotate(360deg) rotateX(62deg); }
      }

      .interference {
        position: absolute; inset: 0; pointer-events: none;
        background: repeating-linear-gradient(
          0deg,
          transparent 0px,
          transparent 3px,
          hsla(calc(var(--hue) + 30), 80%, 55%, 0.02) 3px,
          hsla(calc(var(--hue) + 30), 80%, 55%, 0.02) 4px
        );
        animation: interferenceShift 3.5s steps(8) infinite;
        opacity: calc(0.15 + var(--vel) * 0.25);
        mix-blend-mode: soft-light;
      }
      @keyframes interferenceShift {
        from { transform: translateY(0); }
        to { transform: translateY(32px); }
      }

      .synapse-lines {
        position: absolute; inset: 0; pointer-events: none;
        opacity: 0.04;
        background-image:
          radial-gradient(circle at 20% 30%, hsla(var(--hue), 90%, 60%, 0.5) 1px, transparent 1px),
          radial-gradient(circle at 78% 62%, hsla(calc(var(--hue) + 60), 85%, 55%, 0.45) 1px, transparent 1px),
          radial-gradient(circle at 45% 80%, hsla(calc(var(--hue) - 40), 90%, 58%, 0.4) 1px, transparent 1px);
        background-size: 100% 100%;
        animation: synapsePulse 5s ease-in-out infinite;
      }
      @keyframes synapsePulse {
        0%, 100% { opacity: 0.04; transform: scale(1); }
        50% { opacity: 0.1; transform: scale(1.02); }
      }

      /* faint ICE fall in backdrop */
      .ice-fall {
        position: absolute; inset: 0; pointer-events: none;
        overflow: hidden;
        opacity: calc(0.06 + var(--bloom) * 0.1);
        mask-image: linear-gradient(transparent, #000 20%, #000 80%, transparent);
      }
      .ice-fall span {
        position: absolute;
        top: -1em;
        font-size: 0.45rem;
        letter-spacing: 0.05em;
        color: hsla(var(--hue), 30%, 55%, 0.5);
        animation: iceDrop linear infinite;
        white-space: nowrap;
      }
      @keyframes iceDrop {
        from { transform: translateY(-10vh); opacity: 0; }
        8% { opacity: 0.6; }
        92% { opacity: 0.4; }
        to { transform: translateY(110vh); opacity: 0; }
      }

      .data-stream {
        position: fixed; right: 2.5rem; top: 50%;
        transform: translateY(-50%);
        z-index: 95; pointer-events: none;
        font-size: 0.42rem; letter-spacing: 0.08em;
        color: hsla(calc(var(--hue) + 15), 35%, 62%, calc(0.28 * (1 - var(--focus) * 0.8)));
        writing-mode: vertical-rl;
        text-orientation: mixed;
        line-height: 1.8;
        animation: streamScroll 12s linear infinite;
        max-height: 50vh;
        overflow: hidden;
        mask-image: linear-gradient(transparent, #000 15%, #000 85%, transparent);
      }
      @keyframes streamScroll {
        from { transform: translateY(-40%); }
        to { transform: translateY(-60%); }
      }

      .hud-frame::before, .hud-frame::after,
      .hud-frame span::before, .hud-frame span::after {
        content: '';
        position: absolute;
        width: 24px;
        height: 24px;
        border-color: rgba(var(--ghost-rgb), 0.25);
        border-style: solid;
      }
      .hud-frame::before { top: 0; left: 0; border-width: 1px 0 0 1px; }
      .hud-frame::after { top: 0; right: 0; border-width: 1px 1px 0 0; }
      .hud-frame span::before { bottom: 0; left: 0; border-width: 0 0 1px 1px; }
      .hud-frame span::after { bottom: 0; right: 0; border-width: 0 1px 1px 0; }

      #scroll-progress {
        position: fixed; top: 0; left: 0; width: 100%;         height: 2px;
        background: linear-gradient(90deg,
          var(--violet), var(--magenta), var(--cyber), var(--violet));
        background-size: 200% 100%;
        animation: progressHue 8s linear infinite;
        transform-origin: left; transform: scaleX(0);
        z-index: 200;
        box-shadow: 0 0 12px hsla(var(--hue), 40%, 55%, 0.15);
        opacity: calc(0.7 + (1 - var(--focus)) * 0.3);
      }
      @keyframes progressHue {
        from { background-position: 0% 50%; }
        to { background-position: 200% 50%; }
      }

      .hud-readout {
        position: fixed; z-index: 100; pointer-events: none;
        font-size: 0.52rem; letter-spacing: 0.12em; color: var(--ghost-dim);
        opacity: calc(0.35 + (1 - var(--focus)) * 0.3);
        transition: opacity 0.3s;
      }
      .sector.is-active ~ .hud-readout,
      .sector.is-active .sector-label { color: var(--ghost); }

      .sector.is-active .slab,
      .sector.is-active .clearance-card {
        border-color: rgba(var(--ghost-rgb), calc(0.12 + var(--reveal) * 0.15));
      }
      #dossier.is-active .slab,
      #clearance.is-active .clearance-vault {
        box-shadow:
          0 20px 60px rgba(0, 0, 0, 0.3),
          0 0 0 1px rgba(var(--violet-rgb), calc(0.08 + var(--focus) * 0.12)),
          inset 0 0 30px -12px hsla(var(--hue), 30%, 50%, calc(var(--scan) * 0.08));
      }
      .hud-tl { top: 2rem; left: 2.5rem; }
      .hud-tr { top: 2rem; right: 2.5rem; text-align: right; color: var(--shell-dim); }
      .hud-bl { bottom: 2rem; left: 2.5rem; }
      .hud-br { bottom: 2rem; right: 2.5rem; text-align: right; }

      .boot-screen {
        position: fixed; inset: 0; z-index: 9999; background: var(--void);
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 1.5rem; transition: opacity 0.8s ease, visibility 0.8s ease;
      }
      .boot-screen::before {
        content: '';
        position: absolute; inset: 0; pointer-events: none;
        background: radial-gradient(ellipse at 50% 45%, rgba(184, 168, 224, 0.06) 0%, transparent 55%);
      }
      .boot-screen--hidden { opacity: 0; visibility: hidden; pointer-events: none; }

      .boot-ring {
        position: relative; z-index: 1;
        width: 64px; height: 64px;
        border: 1px solid hsla(var(--hue), 60%, 50%, 0.44);
        border-top-color: var(--magenta);
        border-right-color: var(--cyber);
        border-radius: 50%;
        box-shadow: 0 0 24px rgba(var(--magenta-rgb), 0.12);
        animation: bootSpin 1.2s linear infinite;
      }
      @keyframes bootSpin { to { transform: rotate(360deg); } }

      .boot-label {
        position: relative; z-index: 1;
        font-size: 0.55rem; letter-spacing: 0.35em;
        background: linear-gradient(90deg, var(--magenta), var(--cyber), var(--violet));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-transform: uppercase;
      }
      .boot-status {
        position: relative; z-index: 1;
        font-size: 0.6rem; letter-spacing: 0.1em;
        color: var(--text-dim); animation: pulse 1.4s ease-in-out infinite;
      }
      @keyframes pulse { 0%, 100% { opacity: 0.55; } 50% { opacity: 1; } }

      nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 150;
        display: flex; align-items: center; justify-content: space-between;
        padding: 1.25rem 2.5rem;
        background: linear-gradient(180deg, rgba(16, 14, 26, 0.72) 0%, transparent 100%);
      }

      .nav-brand {
        display: flex; flex-direction: column; gap: 0.15rem;
        text-decoration: none;
      }
      .nav-brand .void {
        font-weight: 700; font-size: 0.8rem; letter-spacing: 0.45em; color: var(--ghost);
        animation: brandGlitch 12s step-end infinite;
      }
      @keyframes brandGlitch {
        0%, 100% { opacity: 1; transform: none; }
        92% { opacity: 1; }
        93% { opacity: 0.7; transform: translateX(-1px); }
        94% { opacity: 1; transform: translateX(1px); }
        95% { opacity: 1; transform: none; }
      }
      .nav-brand .sub {
        font-size: 0.45rem; letter-spacing: 0.2em; color: var(--shell-dim);
        text-transform: uppercase;
      }

      .nav-links { display: flex; gap: 2rem; list-style: none; }
      .nav-links a {
        font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--text-dim); text-decoration: none; transition: color 0.25s;
        position: relative;
      }
      .nav-links a::before {
        content: '›'; margin-right: 0.35rem; color: var(--ghost-dim); opacity: 0;
        transition: opacity 0.2s;
      }
      .nav-links a:hover { color: var(--ghost); }
      .nav-links a:hover::before { opacity: 1; }
      .nav-links a.is-here { color: var(--shell); }

      .nav-exit {
        font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase;
        padding: 0.45rem 1rem;
        border: 1px solid rgba(var(--cyber-rgb), 0.45);
        color: var(--cyber);
        text-decoration: none;
        clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
        transition: background 0.25s, box-shadow 0.25s;
      }
      .nav-exit:hover { background: rgba(var(--cyber-rgb), 0.1); box-shadow: var(--glow-cyber); }

      .net { position: relative; z-index: 10; }

      .sector {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 6rem 2.5rem;
        --section-reveal: 0;
      }

      .sector--hero { align-items: center; justify-content: center; text-align: center; }
      .sector:not(.sector--hero) {
        content-visibility: auto;
        contain-intrinsic-size: auto 800px;
      }

      .hero-wrap, .slab-wrap {
        max-width: 1040px;
        margin: 0 auto;
        width: 100%;
        position: relative;
        opacity: var(--section-reveal, 0);
        transform: translateY(calc((1 - var(--section-reveal, 0)) * 32px))
          scale(calc(0.97 + var(--section-reveal, 0) * 0.03));
      }

      .sector:not(#dossier):not(#clearance) .sector-tag,
      .sector:not(#dossier):not(#clearance) .quote {
        --child-reveal: 0;
        --child-shift: 0px;
        opacity: var(--child-reveal, 0);
        transform: translateX(var(--child-shift, 0));
      }

      .construct-frame {
        position: absolute;
        inset: -2rem;
        pointer-events: none;
        z-index: -1;
      }
      .construct-frame span {
        position: absolute;
        width: 28px;
        height: 28px;
        border-color: hsla(var(--hue), 35%, 55%, 0.2);
        border-style: solid;
        animation: constructCorner 5s ease-in-out infinite;
      }
      .construct-frame span:nth-child(1) {
        top: 0; left: 0;
        border-width: 1px 0 0 1px;
        animation-delay: 0s;
      }
      .construct-frame span:nth-child(2) {
        top: 0; right: 0;
        border-width: 1px 1px 0 0;
        animation-delay: 0.5s;
      }
      .construct-frame span:nth-child(3) {
        bottom: 0; left: 0;
        border-width: 0 0 1px 1px;
        animation-delay: 1s;
      }
      .construct-frame span:nth-child(4) {
        bottom: 0; right: 0;
        border-width: 0 1px 1px 0;
        animation-delay: 1.5s;
      }
      @keyframes constructCorner {
        0%, 100% { opacity: 0.25; transform: scale(1); }
        50% { opacity: 0.7; transform: scale(1.08); }
      }

      .net-mesh {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        opacity: calc(0.04 + var(--bloom) * 0.06);
        background-image:
          linear-gradient(hsla(var(--hue), 30%, 50%, 0.15) 1px, transparent 1px),
          linear-gradient(90deg, hsla(var(--hue), 30%, 50%, 0.15) 1px, transparent 1px);
        background-size: 48px 48px;
        transform: perspective(800px) rotateX(58deg) rotateZ(var(--tilt));
        transform-origin: 50% 80%;
        animation: meshDrift 20s linear infinite;
        mask-image: radial-gradient(ellipse at 50% 60%, #000 20%, transparent 75%);
      }
      @keyframes meshDrift {
        from { background-position: 0 0, 0 0; }
        to { background-position: 0 48px, 48px 0; }
      }

      .sector-tag {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.52rem; letter-spacing: 0.28em; text-transform: uppercase;
        color: hsl(calc(var(--hue) + 20), 40%, 62%);
        margin-bottom: 1.75rem;
        animation: tagFlicker 4s step-end infinite;
      }
      @keyframes tagFlicker {
        0%, 100% { opacity: 1; }
        48% { opacity: 0.85; }
        49% { opacity: 0.4; }
        50% { opacity: 1; }
      }
      .sector-tag::before, .sector-tag::after {
        content: ''; width: 20px; height: 1px;
        background: linear-gradient(90deg, var(--magenta), var(--cyber));
        opacity: 0.6;
      }

      .ghost-title {
        font-weight: 700;
        font-size: clamp(2.5rem, 9vw, 6rem);
        line-height: 0.9;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
        transform: translateY(var(--parallax));
        transition: transform 0.1s linear;
        filter: drop-shadow(0 0 24px hsla(var(--hue), 35%, 50%, 0.12));
      }
      .ghost-title .line { display: block; }
      @keyframes chromaShift {
        from { background-position: 0% center; }
        to { background-position: 200% center; }
      }

      .ghost-title .ghost-word {
        background: linear-gradient(
          120deg,
          hsl(270, 35%, 68%) 0%,
          hsl(195, 35%, 62%) 40%,
          hsl(310, 30%, 65%) 70%,
          hsl(270, 35%, 68%) 100%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        position: relative;
        animation: chromaShift 12s linear infinite, wirePulse 6s ease-in-out infinite, ghostBreath 4s ease-in-out infinite;
      }
      @keyframes ghostBreath {
        0%, 100% { filter: brightness(1); letter-spacing: -0.03em; }
        50% { filter: brightness(1.08); letter-spacing: -0.01em; }
      }
      .ghost-title .ghost-word::before {
        content: '';
        position: absolute;
        left: -5%;
        right: -5%;
        top: 50%;
        height: 1px;
        background: linear-gradient(90deg, transparent, hsla(var(--hue), 40%, 65%, 0.5), transparent);
        animation: holoScan 3.5s ease-in-out infinite;
        pointer-events: none;
      }
      @keyframes holoScan {
        0%, 100% { transform: translateY(-3em); opacity: 0; }
        10% { opacity: 0.6; }
        50% { transform: translateY(0.5em); opacity: 0.4; }
        90% { opacity: 0; }
      }
      .ghost-title .ghost-word::after {
        content: attr(data-text);
        position: absolute;
        left: 0; top: 0;
        color: var(--cyber);
        opacity: 0;
        animation: echoGlitch 9s infinite;
        pointer-events: none;
      }
      .ghost-title .shell-word {
        background: linear-gradient(90deg, hsl(280, 28%, 58%), hsl(200, 28%, 55%));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-size: 0.55em;
        letter-spacing: 0.15em;
        margin-top: 0.15em;
        opacity: 0.8;
        animation: shellDrift 8s ease-in-out infinite, shellPhase 5s ease-in-out infinite;
      }
      @keyframes shellPhase {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(4px); }
      }

      @keyframes wirePulse {
        0%, 100% { opacity: 0.82; }
        50% { opacity: 1; }
      }
      @keyframes shellDrift {
        0%, 100% { letter-spacing: 0.15em; opacity: 0.7; }
        50% { letter-spacing: 0.2em; opacity: 0.9; }
      }
      @keyframes echoGlitch {
        0%, 88%, 100% { opacity: 0; transform: none; filter: none; }
        89% { opacity: 0.6; transform: translate(-4px, 1px) skewX(-2deg); clip-path: inset(10% 0 70% 0); color: var(--magenta); }
        90% { opacity: 0.4; transform: translate(3px, -2px); clip-path: inset(55% 0 15% 0); color: var(--lime); filter: blur(0.5px); }
        91% { opacity: 0.55; transform: translate(-2px, 0); clip-path: inset(30% 0 40% 0); color: var(--cyber); }
        92% { opacity: 0; }
      }

      .quote {
        font-size: clamp(0.75rem, 1.6vw, 0.9rem);
        color: var(--text-dim);
        line-height: 1.8;
        max-width: 50ch;
        margin: 1.75rem auto 0;
        font-style: italic;
        border-top: 1px solid rgba(var(--ghost-rgb), 0.1);
        padding-top: 1.25rem;
      }

      .scroll-cue {
        position: absolute; bottom: 2.5rem; left: 50%;
        transform: translateX(-50%);
        font-size: 0.48rem; letter-spacing: 0.3em;
        color: var(--text-dim);
        animation: drift 3s ease-in-out infinite;
      }
      .scroll-cue em { color: var(--ghost); font-style: normal; }
      @keyframes drift {
        0%, 100% { opacity: 0.3; transform: translateX(-50%); }
        50% { opacity: 0.9; transform: translateX(-50%) translateY(6px); }
      }

      .sector-label {
        font-size: 0.55rem; letter-spacing: 0.25em; text-transform: uppercase;
        color: var(--ghost-dim); margin-bottom: 1.25rem;
      }
      .sector-label span { color: var(--ghost); }

      /* chamfered data slabs */
      .slab {
        background: var(--surface);
        border: 1px solid var(--border);
        backdrop-filter: blur(calc(8px + var(--focus) * 2px));
        -webkit-backdrop-filter: blur(calc(8px + var(--focus) * 2px));
        clip-path: polygon(0 12px, 12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
        position: relative;
        overflow: hidden;
      }
      .slab-scan {
        position: absolute;
        left: 0; right: 0;
        height: 1px;
        pointer-events: none;
        background: linear-gradient(90deg,
          transparent, hsla(var(--hue), 40%, 60%, 0.35), transparent);
        opacity: calc(var(--scan) * 0.8);
        animation: slabScanLine 2.8s ease-in-out infinite;
        z-index: 2;
      }
      @keyframes slabScanLine {
        0% { top: 8%; opacity: 0; }
        15% { opacity: calc(var(--scan) * 0.7); }
        85% { opacity: calc(var(--scan) * 0.5); }
        100% { top: 92%; opacity: 0; }
      }
      .slab::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 60%;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--ghost), transparent);
        animation: slabSweep 5s ease-in-out infinite;
      }
      .slab::after {
        content: '';
        position: absolute;
        top: -100%; left: 0;
        width: 1px;
        height: 40%;
        background: linear-gradient(180deg, transparent, rgba(var(--shell-rgb), 0.4), transparent);
        animation: slabScan 8s linear infinite;
      }
      @keyframes slabSweep {
        0%, 100% { left: -60%; opacity: 0; }
        50% { left: 100%; opacity: 1; }
      }
      @keyframes slabScan {
        0% { top: -40%; opacity: 0; }
        10% { opacity: 0.8; }
        90% { opacity: 0.8; }
        100% { top: 140%; opacity: 0; }
      }

      .slab-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.85rem 1.5rem;
        border-bottom: 1px solid rgba(var(--ghost-rgb), 0.08);
        background: rgba(10, 14, 22, 0.48);
        flex-wrap: wrap; gap: 0.5rem;
      }
      .slab-id {
        font-size: 0.55rem; letter-spacing: 0.15em;
        color: var(--ghost);
      }
      .slab-status {
        font-size: 0.5rem; letter-spacing: 0.12em;
        color: var(--shell);
        animation: statusBlink 3s ease-in-out infinite;
      }
      @keyframes statusBlink {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
      }

      .slab-body { padding: 1.75rem 1.5rem 2rem; }

      .dossier-grid {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 2rem;
        align-items: start;
      }

      #dossier .dossier-grid {
        grid-template-columns: minmax(280px, 42%) 1fr;
        gap: 2rem 2.5rem;
      }

      .stat-col { display: flex; flex-direction: column; gap: 1.25rem; }

      #dossier .stat-col {
        gap: 0;
        min-width: 0;
      }

      #dossier.is-active .stat-block {
        animation: iceRowIn 0.5s ease-out both;
      }
      #dossier.is-active .stat-block:nth-child(1) { animation-delay: 0.2s; }
      #dossier.is-active .stat-block:nth-child(2) { animation-delay: 0.35s; }
      #dossier.is-active .stat-block:nth-child(3) { animation-delay: 0.5s; }
      #dossier.is-active .stat-block:nth-child(4) { animation-delay: 0.65s; }
      @keyframes iceRowIn {
        from {
          opacity: 0;
          clip-path: inset(0 100% 0 0);
          transform: translateY(4px);
        }
        to {
          opacity: 1;
          clip-path: inset(0 0 0 0);
          transform: translateY(0);
        }
      }

      #dossier.is-active .stat-val,
      #dossier.is-active .endpoint {
        animation: iceValGlow 0.6s ease both;
      }
      #dossier.is-active .stat-block:nth-child(1) .stat-val { animation-delay: 0.4s; }
      #dossier.is-active .stat-block:nth-child(2) .stat-val { animation-delay: 0.55s; }
      #dossier.is-active .stat-block:nth-child(3) .stat-val { animation-delay: 0.7s; }
      #dossier.is-active .stat-block:nth-child(4) .endpoint { animation-delay: 0.85s; }
      @keyframes iceValGlow {
        0% {
          opacity: 0;
          color: var(--magenta);
          text-shadow: 0 0 12px rgba(var(--magenta-rgb), 0.6);
        }
        60% {
          opacity: 1;
          text-shadow: 0 0 8px rgba(var(--cyber-rgb), 0.35);
        }
        100% {
          opacity: 1;
          text-shadow: none;
        }
      }

      /* dossier — ICE holo readout */
      #dossier .slab--ice {
        background:
          linear-gradient(165deg, rgba(14, 8, 26, 0.76) 0%, rgba(10, 14, 22, 0.82) 100%);
        border: 1px solid rgba(var(--violet-rgb), 0.28);
        box-shadow:
          0 28px 70px rgba(0, 0, 0, 0.32),
          inset 0 1px 0 rgba(var(--ghost-rgb), 0.08),
          inset 0 0 40px rgba(var(--magenta-rgb), 0.04);
      }

      #dossier.is-active .slab--ice {
        box-shadow:
          0 28px 70px rgba(0, 0, 0, 0.32),
          0 0 40px rgba(var(--violet-rgb), calc(0.06 + var(--focus) * 0.1)),
          inset 0 0 50px -10px hsla(var(--hue), 40%, 50%, calc(var(--scan) * 0.1));
      }

      #dossier .ice-frame {
        position: absolute; inset: 10px; pointer-events: none; z-index: 2;
      }
      #dossier .ice-frame span {
        position: absolute; width: 18px; height: 18px;
        border-color: rgba(var(--ghost-rgb), 0.35);
        border-style: solid;
        animation: iceCorner 3.5s ease-in-out infinite;
      }
      #dossier .ice-frame span:nth-child(1) { top: 0; left: 0; border-width: 1px 0 0 1px; }
      #dossier .ice-frame span:nth-child(2) { top: 0; right: 0; border-width: 1px 1px 0 0; animation-delay: 0.4s; }
      #dossier .ice-frame span:nth-child(3) { bottom: 0; left: 0; border-width: 0 0 1px 1px; animation-delay: 0.8s; }
      #dossier .ice-frame span:nth-child(4) { bottom: 0; right: 0; border-width: 0 1px 1px 0; animation-delay: 1.2s; }
      @keyframes iceCorner {
        0%, 100% { opacity: 0.35; filter: drop-shadow(0 0 0 transparent); }
        50% { opacity: 0.9; filter: drop-shadow(0 0 6px rgba(var(--cyber-rgb), 0.35)); }
      }

      #dossier .ice-shimmer {
        position: absolute; inset: 0; pointer-events: none; z-index: 1;
        background: linear-gradient(
          105deg,
          transparent 42%,
          rgba(var(--ghost-rgb), 0.05) 48%,
          rgba(var(--cyber-rgb), 0.08) 50%,
          rgba(var(--ghost-rgb), 0.05) 52%,
          transparent 58%
        );
        transform: translateX(-120%);
        opacity: calc(0.4 + var(--scan) * 0.4);
      }
      #dossier.is-active .ice-shimmer {
        animation: iceShimmer 4.5s ease-in-out infinite;
      }
      @keyframes iceShimmer {
        0%, 100% { transform: translateX(-120%); }
        45%, 55% { transform: translateX(120%); }
      }

      #dossier .slab-header--ice {
        padding: 0.75rem 1.5rem;
        background: linear-gradient(90deg, rgba(var(--magenta-rgb), 0.06), transparent 60%);
        border-bottom: 1px solid rgba(var(--violet-rgb), 0.15);
        gap: 0.75rem;
      }

      #dossier .ice-id {
        font-size: 0.52rem; letter-spacing: 0.2em;
        color: var(--ghost);
        flex: 1;
      }

      #dossier .ice-badge {
        font-size: 0.42rem; letter-spacing: 0.22em;
        padding: 0.2rem 0.55rem;
        border: 1px solid rgba(var(--magenta-rgb), 0.35);
        color: rgba(var(--magenta-rgb), 0.85);
        clip-path: polygon(4px 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0 100%, 0 4px);
      }

      #dossier .ice-link {
        color: var(--cyber);
        animation: iceLinkPulse 2s ease-in-out infinite;
      }
      @keyframes iceLinkPulse {
        0%, 100% { opacity: 0.55; text-shadow: none; }
        50% { opacity: 1; text-shadow: 0 0 10px rgba(var(--cyber-rgb), 0.45); }
      }

      #dossier .ice-body {
        position: relative;
        padding-top: 1.25rem;
      }

      #dossier .ice-hex {
        position: absolute;
        top: 1.25rem; left: 0.75rem; bottom: 2.5rem;
        width: 3.2rem;
        display: flex; flex-direction: column; gap: 0.35rem;
        font-size: 0.38rem; line-height: 1.45;
        letter-spacing: 0.08em;
        color: rgba(var(--shell-rgb), 0.22);
        overflow: hidden;
        pointer-events: none;
        border-right: 1px solid rgba(var(--ghost-rgb), 0.06);
        padding-right: 0.5rem;
      }
      #dossier.is-active .ice-hex {
        animation: iceHexScroll 12s linear infinite;
      }
      @keyframes iceHexScroll {
        from { transform: translateY(0); }
        to { transform: translateY(-50%); }
      }

      #dossier .ice-grid {
        padding-left: 4rem;
      }

      #dossier .stat-block {
        display: flex;
        align-items: baseline;
        flex-wrap: nowrap;
        gap: 0.4rem;
        width: 100%;
        min-width: 0;
        border-left: none;
        padding-left: 0;
        padding-bottom: 0.75rem;
        margin-bottom: 0.35rem;
        border-bottom: 1px solid rgba(var(--ghost-rgb), 0.06);
      }
      #dossier .stat-block:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

      #dossier .stat-key {
        margin-bottom: 0;
        flex: 0 0 auto;
        white-space: nowrap;
      }
      #dossier .stat-key::before { content: none; }

      #dossier .ice-dots {
        flex: 1 1 auto;
        min-width: 0.75rem;
        height: 0;
        align-self: flex-end;
        margin-bottom: 0.22rem;
        border-bottom: 1px dotted rgba(var(--ghost-rgb), 0.18);
        opacity: 0;
      }

      #dossier .stat-val,
      #dossier .endpoint {
        flex: 0 1 auto;
        min-width: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: right;
        line-height: 1.35;
      }

      #dossier .endpoint {
        display: inline-block;
        max-width: 100%;
      }
      #dossier.is-active .ice-dots {
        animation: iceDotsIn 0.4s ease forwards;
      }
      #dossier.is-active .stat-block:nth-child(1) .ice-dots { animation-delay: 0.3s; }
      #dossier.is-active .stat-block:nth-child(2) .ice-dots { animation-delay: 0.45s; }
      #dossier.is-active .stat-block:nth-child(3) .ice-dots { animation-delay: 0.6s; }
      #dossier.is-active .stat-block:nth-child(4) .ice-dots { animation-delay: 0.75s; }
      @keyframes iceDotsIn { to { opacity: 1; } }

      #dossier .stat-block:hover {
        border-bottom-color: rgba(var(--cyber-rgb), 0.2);
      }
      #dossier .stat-block:hover .stat-val,
      #dossier .stat-block:hover .endpoint {
        color: var(--wire);
        text-shadow: 0 0 8px rgba(var(--wire-rgb), 0.25);
      }

      #dossier .ice-pane { position: relative; }

      #dossier .ice-label {
        font-size: 0.46rem; letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(var(--magenta-rgb), 0.55);
        margin-bottom: 0.5rem;
        opacity: 0;
      }
      #dossier.is-active .ice-label--bio {
        animation: iceLabelIn 0.35s ease forwards;
        animation-delay: 0.95s;
      }
      #dossier.is-active .ice-label--tags {
        animation: iceLabelIn 0.35s ease forwards;
        animation-delay: 1.35s;
      }
      @keyframes iceLabelIn {
        from { opacity: 0; transform: translateX(-8px); }
        to { opacity: 1; transform: translateX(0); }
      }

      #dossier .bio-text {
        border-left: 2px solid rgba(var(--violet-rgb), 0.25);
        padding-left: 0.85rem;
        margin-bottom: 1.1rem;
        opacity: 0;
      }
      #dossier.is-active .bio-text {
        animation: iceBioIn 0.65s ease forwards;
        animation-delay: 1.05s;
      }
      @keyframes iceBioIn {
        from {
          opacity: 0;
          filter: blur(3px);
          border-left-color: transparent;
        }
        to {
          opacity: 1;
          filter: blur(0);
          border-left-color: rgba(var(--violet-rgb), 0.35);
        }
      }

      #dossier .vector-tags {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        align-content: flex-start;
        gap: 0.55rem 0.65rem;
        margin-top: 0.75rem;
      }

      #dossier.is-active .vector-tags .vector-tag {
        animation: iceTagIn 0.4s ease both, netTagPulse 4s ease-in-out infinite;
      }
      #dossier.is-active .vector-tags .vector-tag:nth-child(1) { animation-delay: 1.45s, 0s; }
      #dossier.is-active .vector-tags .vector-tag:nth-child(2) { animation-delay: 1.58s, 0.4s; }
      #dossier.is-active .vector-tags .vector-tag:nth-child(3) { animation-delay: 1.71s, 0.8s; }
      #dossier.is-active .vector-tags .vector-tag:nth-child(4) { animation-delay: 1.84s, 1.2s; }
      #dossier.is-active .vector-tags .vector-tag:nth-child(5) { animation-delay: 1.97s, 1.6s; }
      @keyframes iceTagIn {
        from {
          opacity: 0;
          transform: translateY(8px);
          box-shadow: 0 0 0 rgba(var(--cyber-rgb), 0);
        }
        to {
          opacity: 1;
          transform: translateY(0);
          box-shadow: 0 0 14px rgba(var(--cyber-rgb), 0.12);
        }
      }

      #dossier .vector-tag::before,
      #dossier .vector-tag::after { content: none; }

      #dossier .vector-tag {
        flex: 0 0 auto;
        display: inline-block;
        white-space: nowrap;
        border-color: rgba(var(--violet-rgb), 0.28);
        background: rgba(var(--violet-rgb), 0.06);
      }

      #dossier .ice-wave {
        position: absolute; left: 4rem; right: 1.5rem; bottom: 1rem;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(var(--cyber-rgb), 0.15) 20%,
          rgba(var(--magenta-rgb), 0.35) 50%,
          rgba(var(--cyber-rgb), 0.15) 80%,
          transparent
        );
        opacity: 0;
        transform: scaleX(0.3);
      }
      #dossier.is-active .ice-wave {
        animation: iceWave 1.2s ease forwards, iceWavePulse 3s ease-in-out infinite;
        animation-delay: 0.15s, 1.35s;
      }
      @keyframes iceWave {
        to { opacity: 1; transform: scaleX(1); }
      }
      @keyframes iceWavePulse {
        0%, 100% { opacity: 0.45; filter: blur(0); }
        50% { opacity: 1; filter: blur(0.5px); }
      }

      #dossier .endpoint::before {
        content: '◈';
        color: var(--magenta);
        font-size: 0.55rem;
        margin-right: 0.35rem;
      }

      @media (max-width: 768px) {
        #dossier .ice-hex { display: none; }
        #dossier .ice-grid { padding-left: 0; }
        #dossier .ice-wave { left: 1.5rem; }
      }

      .stat-block {
        border-left: 2px solid rgba(var(--ghost-rgb), 0.2);
        padding-left: 0.85rem;
        transition: opacity 0.15s, transform 0.15s, border-color 0.3s;
      }
      .stat-block:hover {
        border-left-color: var(--ghost);
      }
      .stat-key {
        font-size: 0.48rem; letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--text-dim);
        margin-bottom: 0.3rem;
      }
      .stat-val {
        font-size: 0.78rem; color: var(--text); line-height: 1.5;
      }
      .stat-val--accent { color: var(--cyber); }

      .bio-text {
        font-size: 0.78rem; line-height: 1.85; color: var(--text);
        margin-bottom: 1.25rem;
      }

      .endpoint {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-size: 0.7rem; color: var(--cyber);
        text-decoration: none;
        transition: color 0.2s, text-shadow 0.2s;
      }
      .endpoint::before { content: '⟁'; color: var(--wire); font-size: 0.6rem; }
      .endpoint:hover { color: var(--wire); text-shadow: var(--glow-cyber); }

      .clearance-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.25rem;
        position: relative; z-index: 1;
      }

      /* clearance — credential vault */
      #clearance .clearance-vault {
        position: relative;
        padding: 1.75rem 1.5rem 1.5rem;
        background:
          linear-gradient(160deg, rgba(12, 14, 22, 0.82) 0%, rgba(10, 12, 18, 0.86) 100%);
        border: 1px solid rgba(var(--shell-rgb), 0.14);
        clip-path: polygon(0 12px, 12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
        overflow: hidden;
      }

      #clearance .vault-frame {
        position: absolute; inset: 12px; pointer-events: none; z-index: 2;
      }
      #clearance .vault-frame span {
        position: absolute; width: 22px; height: 22px;
        border-color: rgba(var(--shell-rgb), 0.28);
        border-style: solid;
        animation: vaultCorner 4s ease-in-out infinite;
      }
      #clearance .vault-frame span:nth-child(1) { top: 0; left: 0; border-width: 1px 0 0 1px; }
      #clearance .vault-frame span:nth-child(2) { top: 0; right: 0; border-width: 1px 1px 0 0; animation-delay: 0.5s; }
      #clearance .vault-frame span:nth-child(3) { bottom: 0; left: 0; border-width: 0 0 1px 1px; animation-delay: 1s; }
      #clearance .vault-frame span:nth-child(4) { bottom: 0; right: 0; border-width: 0 1px 1px 0; animation-delay: 1.5s; }
      @keyframes vaultCorner {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 0.85; filter: drop-shadow(0 0 5px rgba(var(--shell-rgb), 0.25)); }
      }

      #clearance .vault-shimmer {
