---
// Neuromancer-inspired console identity panel
---

<div class="ice term theme-ice" id="terminal">
  <div class="rain" aria-hidden="true"></div>

  <div class="term-bar">
    <div class="term-dots">
      <span class="dot r"></span>
      <span class="dot y"></span>
      <span class="dot g"></span>
    </div>
    <div class="term-tabs">
      <div class="term-tab">
        <span class="tab-glyph">◇</span>
        ono-sendai / cyberspace
      </div>
    </div>
    <div class="term-actions">
      <span class="term-status">ICE: disarmed</span>
      <div class="palette">
        <span style="background:#5ce1ff" data-theme="ice" title="ice"></span>
        <span style="background:#ff2a6d" data-theme="magenta" title="ninsei"></span>
        <span style="background:#8b8fa3" data-theme="dead" title="dead channel"></span>
        <span style="background:#e8c547" data-theme="sodium" title="sodium"></span>
        <span style="background:#b967ff" data-theme="uv" title="ultraviolet"></span>
      </div>
    </div>
  </div>

  <div class="term-body">
    <p class="epigraph t0">
      The sky above the port was the color of television, tuned to a dead channel.
    </p>

    <div class="line t1">
      <span class="ps">◈</span><span class="cmd">whoami --jack-in</span>
    </div>

    <div class="fetch t2">
      <pre class="ascii" aria-hidden="true">{`
        ╔══════════════════════╗
        ║  ░▒▓ CYBERSPACE ▓▒░  ║
        ║                      ║
        ║    ┌──┐    ┌──┐      ║
        ║    │██│────│██│      ║
        ║    └──┘    └──┘      ║
        ║       \\  /           ║
        ║        \\/            ║
        ║     [ CONSOLE ]      ║
        ║      COWBOY           ║
        ╚══════════════════════╝
      `}</pre>
      <div class="info">
        <div class="info-sep">── consensual hallucination ──</div>
        <div class="info-row">
          <span class="ik">handle</span>
          <span class="iv">n0m-d · console operator</span>
        </div>
        <div class="info-row">
          <span class="ik">about</span>
          <span class="iv">
            Mostly application security. CVE analysis, web vulnerabilities,
            code auditing — and whatever catches attention beyond that.
          </span>
        </div>
        <div class="info-row">
          <span class="ik">github</span>
          <a href="https://github.com/n0m-d" target="_blank" class="il">github.com/n0m-d</a>
        </div>
        <div class="info-row">
          <span class="ik">creds</span>
          <ul class="certs-list">
            <li class="cert-category">
              <span class="cert-name">HTB</span>
              <ul class="cert-items">
                <li class="cert-item">
                  <a href="https://academy.hackthebox.com/preview/certifications/htb-certified-web-exploitation-expert" target="_blank">CWEE</a>
                </li>
              </ul>
            </li>
            <li class="cert-category">
              <span class="cert-name">APIsec</span>
              <ul class="cert-items">
                <li class="cert-item">ASCP</li>
                <li class="cert-item">CASA</li>
                <li class="cert-item">ACP</li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="out t3">
      <span class="dim">//</span> jacking out. connection severed at user request.
    </div>

    <div class="line t4">
      <span class="ps">◈</span><span class="cursor"></span>
    </div>
  </div>
</div>

<script>
  const themes = {
    ice: { color: '#5ce1ff', secondary: '#9ef0ff', dark: '#1a6b8a' },
    magenta: { color: '#ff2a6d', secondary: '#ff6b9d', dark: '#a81850' },
    dead: { color: '#8b8fa3', secondary: '#b8bcc9', dark: '#4a4e5c' },
    sodium: { color: '#e8c547', secondary: '#f5df7a', dark: '#9a7f1e' },
    uv: { color: '#b967ff', secondary: '#d4a5ff', dark: '#6b2fa8' },
  };

  function hexToRgb(hex: string) {
    const cleaned = hex.replace('#', '');
    const bigint = parseInt(cleaned, 16);
    return `${(bigint >> 16) & 255}, ${(bigint >> 8) & 255}, ${bigint & 255}`;
  }

  function switchTheme(themeName: string) {
    const theme = themes[themeName as keyof typeof themes];
    if (!theme) return;
    const term = document.getElementById('terminal');
    if (!term) return;
    term.style.setProperty('--theme-color', theme.color);
    term.style.setProperty('--theme-color-rgb', hexToRgb(theme.color));
    term.style.setProperty('--theme-secondary', theme.secondary);
    term.style.setProperty('--theme-secondary-rgb', hexToRgb(theme.secondary));
    term.style.setProperty('--theme-dark', theme.dark);
    term.style.setProperty('--theme-dark-rgb', hexToRgb(theme.dark));
    document.querySelectorAll('.palette span').forEach((s) => s.classList.remove('active'));
    document.querySelector(`.palette span[data-theme="${themeName}"]`)?.classList.add('active');
  }

  function bindThemePalette() {
    document.querySelectorAll('.palette span[data-theme]').forEach((span) => {
      span.addEventListener('click', () => {
        const themeName = (span as HTMLElement).dataset.theme;
        if (themeName) switchTheme(themeName);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      bindThemePalette();
      switchTheme('ice');
    });
  } else {
    bindThemePalette();
    switchTheme('ice');
  }
</script>

<style>
  @layer starlight.core {
    .ice {
      --port-bg: #08080f;
      --port-rain: rgba(92, 225, 255, 0.04);
      width: 100%;
      max-width: none;
      margin: 0 auto;
      background: linear-gradient(165deg, rgba(10, 10, 18, 0.96) 0%, rgba(6, 6, 12, 0.98) 100%);
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid rgba(92, 225, 255, 0.12);
      box-shadow:
        0 0 0 1px rgba(255, 42, 109, 0.04),
        0 24px 60px rgba(0, 0, 0, 0.55),
        inset 0 1px 0 rgba(92, 225, 255, 0.06);
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      position: relative;
    }

    .rain {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: 0.35;
      background-image: repeating-linear-gradient(
        105deg,
        transparent,
        transparent 4px,
        var(--port-rain) 4px,
        var(--port-rain) 5px
      );
      animation: rainFall 0.8s linear infinite;
    }

    @keyframes rainFall {
      from { background-position: 0 0; }
      to { background-position: -40px 80px; }
    }

    .ice::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 50% 0%, rgba(92, 225, 255, 0.06), transparent 60%),
        radial-gradient(ellipse 40% 30% at 90% 80%, rgba(255, 42, 109, 0.05), transparent 50%);
      pointer-events: none;
    }

    .ice::after {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.04) 2px,
        rgba(0, 0, 0, 0.04) 4px
      );
      pointer-events: none;
      opacity: 0.5;
    }

    .term-bar {
      background: rgba(6, 6, 14, 0.9);
      padding: 0.75rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(92, 225, 255, 0.1);
      position: relative;
      z-index: 3;
    }

    .term-dots { display: flex; gap: 6px; }
    .dot { width: 10px; height: 10px; border-radius: 50%; opacity: 0.85; }
    .dot.r { background: #ff2a6d; box-shadow: 0 0 6px rgba(255, 42, 109, 0.4); }
    .dot.y { background: #e8c547; }
    .dot.g { background: #5ce1ff; box-shadow: 0 0 6px rgba(92, 225, 255, 0.3); }

    .term-tabs { display: flex; gap: 0.25rem; }
    .term-tab {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.65rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(158, 240, 255, 0.7);
      border: 1px solid rgba(92, 225, 255, 0.15);
      padding: 0.35rem 0.75rem;
      background: rgba(92, 225, 255, 0.04);
    }

    .tab-glyph { color: #ff2a6d; font-size: 0.55rem; }

    .term-actions { display: flex; align-items: center; gap: 0.85rem; }

    .term-status {
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(92, 225, 255, 0.55);
      animation: statusPulse 4s ease-in-out infinite;
    }

    @keyframes statusPulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }

    .term-body {
      padding: 1.75rem 2rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      position: relative;
      z-index: 1;
    }

    .epigraph {
      font-size: 0.68rem;
      font-style: italic;
      color: rgba(139, 143, 163, 0.75);
      line-height: 1.6;
      max-width: 42ch;
      border-left: 2px solid rgba(255, 42, 109, 0.35);
      padding-left: 0.85rem;
      margin-bottom: 0.5rem;
    }

    .line {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
    }

    .ps {
      color: var(--theme-color, #5ce1ff);
      text-shadow: 0 0 10px rgba(var(--theme-color-rgb, 92, 225, 255), 0.5);
    }

    .cmd { color: rgba(200, 210, 230, 0.75); }
    .dim { color: rgba(139, 143, 163, 0.55); font-size: 0.72rem; }

    .fetch {
      display: flex;
      gap: 2.5rem;
      margin: 0.5rem 0;
      align-items: flex-start;
      flex-wrap: wrap;
    }

    pre.ascii, .ascii {
      margin: 0;
      font-size: 0.52rem;
      line-height: 1.35;
      color: rgba(var(--theme-secondary-rgb, 158, 240, 255), 0.75);
      white-space: pre;
      flex-shrink: 0;
      animation: matrixFlicker 6s ease-in-out infinite;
    }

    @keyframes matrixFlicker {
      0%, 100% { opacity: 0.85; }
      48% { opacity: 0.85; }
      50% { opacity: 0.65; }
      52% { opacity: 0.9; }
    }

    .info {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      flex: 1;
      min-width: 260px;
    }

    .info-sep {
      color: rgba(var(--theme-color-rgb, 92, 225, 255), 0.35);
      font-size: 0.62rem;
      letter-spacing: 0.15em;
      margin-bottom: 0.25rem;
    }

    .info-row {
      display: flex;
      gap: 0.85rem;
      font-size: 0.72rem;
      align-items: baseline;
      line-height: 1.65;
    }

    .ik {
      color: var(--theme-color, #5ce1ff);
      min-width: 4rem;
      opacity: 0.85;
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .iv { color: rgba(180, 190, 210, 0.65); }

    .il {
      color: #ff6b9d;
      text-decoration: none;
      transition: color 0.2s, text-shadow 0.2s;
    }
    .il:hover {
      color: #fff;
      text-shadow: 0 0 8px rgba(255, 42, 109, 0.5);
    }

    .certs-list { list-style: none; padding: 0; margin: 0; }
    .cert-category { margin-bottom: 0.5rem; }
    .cert-name {
      color: var(--theme-color, #5ce1ff);
      font-size: 0.65rem;
      letter-spacing: 0.06em;
      margin-right: 0.35rem;
    }
    .cert-items { list-style: none; padding-left: 1rem; margin: 0.25rem 0 0; }
    .cert-item {
      font-size: 0.68rem;
      color: rgba(200, 190, 220, 0.6);
      padding-left: 0.75rem;
      position: relative;
      margin-bottom: 0.2rem;
    }
    .cert-item::before {
      content: '│';
      position: absolute;
      left: 0;
      color: rgba(255, 42, 109, 0.4);
      font-size: 0.6rem;
    }
    .cert-item a { color: inherit; text-decoration: none; }
    .cert-item a:hover { color: #ff6b9d; }

    .out {
      font-size: 0.7rem;
      color: rgba(139, 143, 163, 0.6);
      padding-left: 0.75rem;
      border-left: 1px solid rgba(92, 225, 255, 0.15);
      margin-top: 0.25rem;
    }

    .cursor {
      display: inline-block;
      width: 8px;
      height: 1.1rem;
      background: var(--theme-color, #5ce1ff);
      animation: blink 1.1s step-end infinite;
      box-shadow: 0 0 10px rgba(var(--theme-color-rgb, 92, 225, 255), 0.6);
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    .palette { display: flex; gap: 6px; }
    .palette span {
      width: 14px;
      height: 14px;
      border-radius: 2px;
      cursor: pointer;
      border: 1px solid rgba(255, 255, 255, 0.15);
      opacity: 0.75;
      transition: transform 0.2s, opacity 0.2s;
    }
    .palette span:hover { transform: scale(1.15); opacity: 1; }
    .palette span.active {
      outline: 1px solid rgba(255, 255, 255, 0.6);
      transform: scale(1.1);
    }

    .t0, .t1, .t2, .t3, .t4 {
      opacity: 0;
      animation: fadein 0.5s ease forwards;
    }
    .t0 { animation-delay: 0.15s; }
    .t1 { animation-delay: 0.45s; }
    .t2 { animation-delay: 0.75s; }
    .t3 { animation-delay: 1.2s; }
    .t4 { animation-delay: 1.5s; }

    @keyframes fadein {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 560px) {
      .term-body { padding: 1.25rem; }
      .fetch { gap: 1.25rem; flex-direction: column; }
      .ascii { font-size: 0.42rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .rain, .term-status, .ascii, .cursor, .t0, .t1, .t2, .t3, .t4 {
        animation: none !important;
        opacity: 1 !important;
      }
    }
  }
</style>
