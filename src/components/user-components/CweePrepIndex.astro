---
import { getCollection } from "astro:content";

const allDocs = await getCollection("docs");
const entries = allDocs.filter(
  (e) =>
    e.id.startsWith("cwee-prep-track/") &&
    !e.id.startsWith("cwee-prep-track/introduction/")
);

const groups = new Map<string, typeof entries>();
for (const entry of entries) {
  const parts = entry.id.replace("cwee-prep-track/", "").split("/");
  const category = parts.length > 1 ? parts[0] : "general";
  if (!groups.has(category)) groups.set(category, []);
  groups.get(category)!.push(entry);
}

const sorted = [...groups.entries()].sort(([a], [b]) => {
  if (a === "general") return -1;
  if (b === "general") return 1;
  return a.localeCompare(b);
});

for (const [, items] of sorted) {
  items.sort((a, b) => a.data.title.localeCompare(b.data.title));
}

function formatCategory(name: string) {
  return name
    .split(/[-_]/)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

const totalCount = entries.length;
---

<div class="index">
  {
    sorted.length === 0 ? (
      <div class="empty">
        <span class="empty__pulse" aria-hidden="true" />
        <p class="empty__title">No materials yet</p>
        <p class="empty__desc">Check back soon — new write-ups will appear here.</p>
      </div>
    ) : (
      <>
        <div class="summary">
          <span class="summary__dot" aria-hidden="true" />
          <span class="summary__count">{totalCount}</span>
          <span class="summary__label">
            {totalCount === 1 ? "entry" : "entries"} indexed
          </span>
        </div>

        {sorted.map(([category, items]) => (
          <section class="group">
            <header class="group__header">
              <h3 class="group__title">{formatCategory(category)}</h3>
              <span class="group__badge">{items.length}</span>
            </header>

            <ul class="list">
              {items.map((entry, i) => (
                <li>
                  <a href={`/${entry.id}/`} class="card">
                    <span class="card__index">{String(i + 1).padStart(2, "0")}</span>
                    <span class="card__body">
                      <span class="card__title">{entry.data.title}</span>
                      {entry.data.description && (
                        <span class="card__desc">{entry.data.description}</span>
                      )}
                    </span>
                    <span class="card__arrow" aria-hidden="true">
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 16 16"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M3 8H13M13 8L9 4M13 8L9 12"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </>
    )
  }
</div>

<style>
  .index {
    --index-accent: #b8d94a;
    --index-accent-gradient: linear-gradient(
      135deg,
      #8fb832 0%,
      #b8d94a 45%,
      #e4f07a 100%
    );
    --index-accent-glow: color-mix(in srgb, #b8d94a 55%, transparent);
    --index-accent-soft: color-mix(in srgb, #b8d94a 22%, transparent);
    --index-accent-muted: color-mix(in srgb, #b8d94a 25%, transparent);

    margin-top: 0.5rem;
  }

  .summary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.5rem;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-6);
    background: color-mix(in oklab, var(--sl-color-gray-6) 22%, transparent);
    font-size: var(--sl-text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .summary__dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--index-accent-gradient);
    box-shadow: 0 0 8px var(--index-accent-glow);
  }

  .summary__count {
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .summary__label {
    color: var(--sl-color-gray-3);
  }

  .empty {
    position: relative;
    margin-top: 0.5rem;
    padding: 2.5rem 1.5rem;
    text-align: center;
    border-radius: 1rem;
    border: 1px dashed var(--sl-color-gray-5);
    background: color-mix(in oklab, var(--sl-color-gray-6) 12%, transparent);
    overflow: hidden;
  }

  .empty__pulse {
    display: block;
    width: 2.5rem;
    height: 2.5rem;
    margin: 0 auto 1rem;
    border-radius: 50%;
    border: 1px solid var(--sl-color-gray-5);
    background: radial-gradient(
      circle at center,
      var(--index-accent-muted) 0%,
      transparent 70%
    );
    animation: pulse 2.4s ease-in-out infinite;
  }

  .empty__title {
    margin: 0 0 0.35rem;
    font-size: var(--sl-text-h5);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .empty__desc {
    margin: 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }

  .group {
    margin-top: 1.25rem;
    padding: 0.35rem;
    border-radius: 1.15rem;
    border: 1px solid var(--sl-color-gray-6);
    background: color-mix(in oklab, var(--sl-color-black) 88%, var(--sl-color-gray-6));
  }

  .group__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1rem 0.65rem;
  }

  .group__title {
    margin: 0;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--sl-color-gray-2);
  }

  .group__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.45rem;
    border-radius: 999px;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    color: var(--sl-color-white);
    background: color-mix(in oklab, var(--sl-color-gray-6) 55%, transparent);
    border: 1px solid var(--sl-color-gray-5);
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem 1rem;
    padding: 0.85rem 1rem;
    border-radius: 0.85rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    background: color-mix(in oklab, var(--sl-color-gray-6) 18%, transparent);
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    overflow: hidden;
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: var(--index-accent-gradient);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .card::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--index-accent-gradient);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .card:hover {
    background: color-mix(in oklab, var(--sl-color-gray-6) 32%, transparent);
    transform: translateX(2px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--sl-color-black) 35%, transparent);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card:hover::after {
    opacity: 1;
  }

  .card__index {
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-4);
    transition: color 0.2s ease;
  }

  .card:hover .card__index {
    color: var(--index-accent);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .card__title {
    font-size: var(--sl-text-body);
    font-weight: 600;
    color: var(--sl-color-white);
    line-height: 1.35;
  }

  .card__desc {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    color: var(--sl-color-gray-4);
    background: color-mix(in oklab, var(--sl-color-gray-6) 40%, transparent);
    transition:
      color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .card:hover .card__arrow {
    color: var(--sl-color-white);
    background: var(--index-accent-soft);
    transform: translateX(2px);
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.65;
    }
    50% {
      transform: scale(1.08);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .card {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
    }

    .card__arrow {
      grid-column: 2;
      justify-self: end;
      margin-top: -1.75rem;
    }
  }
</style>
