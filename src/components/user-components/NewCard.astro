---
import { Icon } from "@astrojs/starlight/components";

const { icon, title, iconColor, size = "large", href, glossy = false } = Astro.props;
const Tag = href ? "a" : "article";
const cardStyle = iconColor ? `--card-accent: ${iconColor};` : undefined;
---

<Tag
  href={href}
  style={cardStyle}
  class={`card bg-lightmode-dark dark:bg-dark group ${glossy ? "card--glossy" : ""} ${size === "sm" ? "p-6" : "py-12 px-10"}`}
>
  {glossy && <span class="card-gloss" aria-hidden="true" />}
  {
    icon && (
      <Icon
        name={icon}
        class="icon"
        size={`${size === "sm" ? "1.4rem" : "2rem"}`}
        color={iconColor}
      />
    )
  }
  <p class="title mt-11 mb-4">
    <span set:html={title} />
  </p>
  <div class="body"><slot /></div>
  {
    size === "sm" ? (
      ""
    ) : (
      <div class="mt-15">
        <span>
          <svg
            class="transition-transform duration-300 group-hover:-rotate-45"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M10.3209 0.715753L17.3509 7.84376C17.7823 8.28117 17.7823 8.99035 17.3509 9.42776L10.3209 16.5558C9.88952 16.9932 9.1901 16.9932 8.7587 16.5558C8.32731 16.1184 8.32731 15.4092 8.7587 14.9718L13.9029 9.75582H1.10465C0.494569 9.75582 0 9.25435 0 8.63576C0 8.01717 0.494569 7.5157 1.10465 7.5157H13.9029L8.7587 2.29975C8.32731 1.86234 8.32731 1.15316 8.7587 0.715753C9.1901 0.278343 9.88952 0.278343 10.3209 0.715753Z"
              class="fill-lightmode-light dark:fill-light"
            />
          </svg>
        </span>
      </div>
    )
  }
</Tag>

<style>
  @layer starlight.components {
    .card {
      display: flex;
      /* padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem); */
      /* padding: 48px 40px; */
      flex-direction: column;
      /* gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem); */
      border-radius: 1rem;
      position: relative;
      transition: all 0.5s ease;
      border: 1px solid color-mix(in srgb, var(--card-accent, var(--sl-color-gray-6)) 42%, var(--sl-color-gray-6));
      text-decoration: none;
      color: inherit;
    }
   
    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      padding: 1px;
      background: linear-gradient(
        135deg,
        color-mix(in srgb, var(--card-accent, var(--sl-color-accent)) 70%, transparent) 0%,
        var(--card-accent, var(--sl-color-accent)) 50%,
        color-mix(in srgb, var(--card-accent, var(--sl-color-accent)) 75%, white) 100%
      );
      border-radius: inherit;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: exclude;
      -webkit-mask-composite: xor;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .card:hover::before {
      opacity: 1;
    }

    .card:hover {
      border-color: color-mix(in srgb, var(--card-accent, var(--sl-color-gray-6)) 65%, transparent);
    }

    .card--glossy {
      overflow: hidden;
      border-color: color-mix(in srgb, var(--card-accent, var(--sl-color-gray-6)) 55%, transparent);
      background: linear-gradient(
        155deg,
        color-mix(in oklab, var(--sl-color-gray-6) 38%, var(--sl-color-black)) 0%,
        color-mix(in oklab, var(--sl-color-black) 94%, var(--sl-color-gray-6)) 55%,
        color-mix(in oklab, var(--sl-color-gray-6) 22%, var(--sl-color-black)) 100%
      ) !important;
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--card-accent, var(--sl-color-white)) 18%, transparent),
        0 10px 28px color-mix(in srgb, var(--card-accent, var(--sl-color-black)) 14%, var(--sl-color-black));
    }

    .card--glossy:hover {
      border-color: color-mix(in srgb, var(--card-accent, var(--sl-color-gray-6)) 80%, transparent);
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--card-accent, var(--sl-color-white)) 28%, transparent),
        0 12px 32px color-mix(in srgb, var(--card-accent, var(--sl-color-black)) 22%, var(--sl-color-black));
    }

    .card-gloss {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      pointer-events: none;
      z-index: 0;
      background:
        linear-gradient(
          145deg,
          color-mix(in srgb, var(--sl-color-white) 16%, transparent) 0%,
          color-mix(in srgb, var(--sl-color-white) 5%, transparent) 24%,
          transparent 48%
        ),
        linear-gradient(
          325deg,
          transparent 58%,
          color-mix(in srgb, var(--sl-color-white) 7%, transparent) 100%
        );
      opacity: 0.9;
      transition: opacity 0.35s ease;
    }

    .card-gloss::after {
      content: "";
      position: absolute;
      top: 0;
      left: -120%;
      width: 50%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent,
        color-mix(in srgb, var(--sl-color-white) 22%, transparent),
        transparent
      );
      transform: skewX(-20deg);
    }

    .card--glossy:hover .card-gloss {
      opacity: 1;
    }

    .card--glossy:hover .card-gloss::after {
      animation: card-gloss-sweep 0.85s ease;
    }

    .card--glossy .icon,
    .card--glossy .title,
    .card--glossy .body,
    .card--glossy > div {
      position: relative;
      z-index: 1;
    }

    @keyframes card-gloss-sweep {
      0% {
        left: -120%;
      }
      100% {
        left: 140%;
      }
    }

    .title {
      font-size: var(--sl-text-h4);
      color: var(--sl-color-white);
      line-height: var(--sl-line-height-headings);
      gap: 1rem;
      align-items: center;
    }

    .card .body {
      margin: 0;
      font-size: clamp(var(--sl-text-body));
    }
  }
</style>
