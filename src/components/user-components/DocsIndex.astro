---
import { getCollection } from "astro:content";

interface Props {
  rootId: string;
  contentPrefix: string;
  introPrefix: string;
  accent: string;
}

const { rootId, contentPrefix, introPrefix, accent } = Astro.props;

const allDocs = await getCollection("docs");
const entries = allDocs.filter(
  (e) => e.id.startsWith(contentPrefix) && !e.id.startsWith(introPrefix)
);

function getCategory(id: string) {
  const parts = id.replace(contentPrefix, "").split("/");
  return parts.length > 1 ? parts[0] : "general";
}

function formatCategory(name: string) {
  return name
    .split(/[-_]/)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

const flat = entries
  .map((entry) => ({
    entry,
    category: getCategory(entry.id),
  }))
  .sort((a, b) => a.entry.data.title.localeCompare(b.entry.data.title));

const categories = [...new Set(flat.map((item) => item.category))].sort((a, b) => {
  if (a === "general") return -1;
  if (b === "general") return 1;
  return a.localeCompare(b);
});

const categoryCounts = Object.fromEntries(
  categories.map((cat) => [cat, flat.filter((item) => item.category === cat).length])
);

const totalCount = flat.length;
const defaultPerPage = 10;
const searchId = `${rootId}-search`;
---

<div
  class="docs-index"
  id={rootId}
  data-docs-index
  style={`--index-accent: ${accent};`}
>
  {
    flat.length === 0 ? (
      <div class="empty">
        <span class="empty__pulse" aria-hidden="true" />
        <p class="empty__title">No materials yet</p>
        <p class="empty__desc">Check back soon — new write-ups will appear here.</p>
      </div>
    ) : (
      <>
        <div class="toolbar">
          <div class="toolbar__row">
            <div class="summary">
              <span class="summary__dot" aria-hidden="true" />
              <span class="summary__count" data-index-counter>{totalCount}</span>
              <span class="summary__label">
                {totalCount === 1 ? "entry" : "entries"}
              </span>
            </div>

            <label class="search" for={searchId}>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M10.68 11.74a6 6 0 0 1-7.922-8.982 6 6 0 0 1 8.982 7.922l3.04 3.04a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215ZM11.5 7a4.499 4.499 0 1 0-8.997 0A4.499 4.499 0 0 0 11.5 7Z" />
              </svg>
              <input
                id={searchId}
                data-index-search
                type="search"
                placeholder="Search write-ups…"
                autocomplete="off"
                spellcheck="false"
              />
              <kbd class="search__kbd" aria-hidden="true">/</kbd>
            </label>
          </div>

          <div
            class="filters"
            data-index-filters
            role="group"
            aria-label="Filter by category"
          >
            <button type="button" class="filter-pill is-active" data-filter="all">
              <span class="filter-pill__inner">
                <span class="filter-pill__label">All</span>
                <span class="filter-pill__count">{totalCount}</span>
              </span>
            </button>
            {categories.map((category) => (
              <button type="button" class="filter-pill" data-filter={category}>
                <span class="filter-pill__inner">
                  <span class="filter-pill__label">{formatCategory(category)}</span>
                  <span class="filter-pill__count">{categoryCounts[category]}</span>
                </span>
              </button>
            ))}
          </div>
        </div>

        <ul class="list" data-index-list>
          {flat.map((item, i) => {
            const searchText = [
              item.entry.data.title,
              item.entry.data.description ?? "",
              formatCategory(item.category),
              item.category,
            ]
              .join(" ")
              .toLowerCase();

            return (
              <li
                class="index-item"
                data-category={item.category}
                data-search={searchText}
              >
                <a href={`/${item.entry.id}/`} class="card">
                  <span class="card__index">{String(i + 1).padStart(2, "0")}</span>
                  <span class="card__body">
                    <span class="card__meta">
                      <span class="card__category">{formatCategory(item.category)}</span>
                    </span>
                    <span class="card__title">{item.entry.data.title}</span>
                    {item.entry.data.description && (
                      <span class="card__desc">{item.entry.data.description}</span>
                    )}
                  </span>
                  <span class="card__arrow" aria-hidden="true">
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M3 8H13M13 8L9 4M13 8L9 12"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              </li>
            );
          })}
        </ul>

        <div class="empty empty--search" data-index-empty hidden>
          <span class="empty__pulse" aria-hidden="true" />
          <p class="empty__title">No matches</p>
          <p class="empty__desc">Try a different search term or category filter.</p>
        </div>

        <div class="pagination" data-index-pagination>
          <div class="pagination__info">
            <label for={`${rootId}-per-page`}>
              Per page
              <select
                id={`${rootId}-per-page`}
                data-index-per-page
                aria-label="Entries per page"
              >
                <option value="5">5</option>
                <option value="10" selected>10</option>
                <option value="15">15</option>
                <option value="25">25</option>
              </select>
            </label>
            <span data-index-page-range>
              Showing 1–{Math.min(defaultPerPage, totalCount)} of {totalCount}
            </span>
          </div>
          <div class="pagination__nav">
            <button type="button" class="page-btn" data-index-prev-page disabled>
              Previous
            </button>
            <span class="pagination__indicator" data-index-page-indicator>
              Page 1 of {Math.max(1, Math.ceil(totalCount / defaultPerPage))}
            </span>
            <button type="button" class="page-btn" data-index-next-page>
              Next
            </button>
          </div>
        </div>
      </>
    )
  }
</div>

<script>
  import { bootDocsIndex } from "../../scripts/docs-index.ts";

  function bootAllDocsIndexes(): void {
    document.querySelectorAll<HTMLElement>("[data-docs-index]").forEach((root) => {
      if (root.id) bootDocsIndex(root.id, { defaultPerPage: 10 });
    });
  }

  bootAllDocsIndexes();
  document.addEventListener("astro:page-load", bootAllDocsIndexes);
</script>

<style>
  .docs-index {
    --index-black: #111111;
    --index-dark: #1a1a1a;
    --index-white: #ffffff;
    --index-border: color-mix(in srgb, var(--index-white) 12%, transparent);
    --index-muted: color-mix(in srgb, var(--index-white) 55%, transparent);
    --index-subtle: color-mix(in srgb, var(--index-white) 35%, transparent);
    --index-accent-gradient: linear-gradient(
      135deg,
      color-mix(in srgb, var(--index-accent) 70%, #000) 0%,
      var(--index-accent) 50%,
      color-mix(in srgb, var(--index-accent) 75%, var(--index-white)) 100%
    );
    --index-accent-glow: color-mix(in srgb, var(--index-accent) 55%, transparent);
    --index-accent-soft: color-mix(in srgb, var(--index-accent) 18%, transparent);
    --index-accent-muted: color-mix(in srgb, var(--index-accent) 22%, transparent);

    margin-top: 0.5rem;
    color: var(--index-white);
  }

  .toolbar {
    margin-bottom: 1.25rem;
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid var(--index-border);
    background:
      radial-gradient(
        ellipse 80% 60% at 100% 0%,
        color-mix(in srgb, var(--index-accent) 10%, transparent),
        transparent 55%
      ),
      var(--index-dark);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--index-black) 65%, transparent);
  }

  .toolbar__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem 1.25rem;
    margin-bottom: 0.9rem;
  }

  .summary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    height: 2rem;
    padding: 0 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--index-border);
    background: color-mix(in srgb, var(--index-black) 55%, var(--index-dark));
    font-size: var(--sl-text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
  }

  .summary__dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--index-accent-gradient);
    box-shadow: 0 0 8px var(--index-accent-glow);
  }

  .summary__count {
    font-weight: 700;
    color: var(--index-white);
  }

  .summary__label {
    color: var(--index-muted);
  }

  .search {
    position: relative;
    flex: 1;
    min-width: min(100%, 16rem);
    max-width: 22rem;
    margin-left: auto;
  }

  .search svg {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--index-subtle);
    pointer-events: none;
  }

  .search input {
    width: 100%;
    height: 2rem;
    padding: 0 2.5rem 0 2.35rem;
    border-radius: 0.75rem;
    border: 1px solid var(--index-border);
    background: var(--index-black);
    color: var(--index-white);
    font: inherit;
    font-size: var(--sl-text-sm);
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .search input::placeholder {
    color: var(--index-subtle);
  }

  .search input:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--index-accent) 65%, var(--index-border));
    background: color-mix(in srgb, var(--index-black) 80%, var(--index-dark));
    box-shadow: 0 0 0 3px var(--index-accent-soft);
  }

  .search__kbd {
    position: absolute;
    right: 0.65rem;
    top: 50%;
    transform: translateY(-50%);
    padding: 0.1rem 0.4rem;
    border-radius: 0.35rem;
    border: 1px solid var(--index-border);
    background: var(--index-dark);
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    color: var(--index-subtle);
    line-height: 1.4;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .filter-pill {
    display: block;
    margin: 0;
    padding: 0;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid var(--index-border);
    background: var(--index-black);
    color: var(--index-muted);
    font-family: inherit;
    font-size: var(--sl-text-xs);
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.03em;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .filter-pill__inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    height: 100%;
    padding: 0 0.85rem;
    white-space: nowrap;
  }

  .filter-pill__label {
    display: inline-flex;
    align-items: center;
    height: 100%;
    line-height: 1;
  }

  .filter-pill:hover {
    border-color: color-mix(in srgb, var(--index-accent) 35%, var(--index-border));
    color: var(--index-white);
    background: color-mix(in srgb, var(--index-dark) 70%, var(--index-black));
  }

  .filter-pill.is-active {
    border-color: color-mix(in srgb, var(--index-accent) 55%, var(--index-border));
    color: var(--index-white);
    background: var(--index-accent-soft);
  }

  .filter-pill__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    line-height: 1;
    color: var(--index-muted);
    background: color-mix(in srgb, var(--index-white) 8%, var(--index-dark));
  }

  .filter-pill.is-active .filter-pill__count {
    color: var(--index-accent);
    background: color-mix(in srgb, var(--index-accent) 18%, var(--index-dark));
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .index-item {
    content-visibility: auto;
    contain-intrinsic-size: auto 4.75rem;
  }

  .index-item.is-filtered-out,
  .index-item[hidden] {
    display: none !important;
  }

  .card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.85rem 1rem;
    padding: 0.9rem 1rem;
    border-radius: 0.9rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--index-border);
    background: var(--index-dark);
    contain: layout paint;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: var(--index-accent-gradient);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    opacity: 0;
    transition: opacity 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
    will-change: opacity;
  }

  .card::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--index-accent-gradient);
    opacity: 0;
    transition: opacity 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: opacity;
  }

  .card:hover {
    background: color-mix(in srgb, var(--index-dark) 65%, var(--index-black));
    border-color: color-mix(in srgb, var(--index-accent) 30%, var(--index-border));
    transform: translate3d(2px, 0, 0);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--index-black) 55%, transparent);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card:hover::after {
    opacity: 1;
  }

  .card__index {
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--index-subtle);
    transition: color 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card:hover .card__index {
    color: var(--index-accent);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card__category {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--index-accent);
    background: var(--index-accent-soft);
    border: 1px solid color-mix(in srgb, var(--index-accent) 35%, transparent);
  }

  .card__title {
    font-size: var(--sl-text-body);
    font-weight: 600;
    color: var(--index-white);
    line-height: 1.35;
  }

  .card__desc {
    font-size: var(--sl-text-sm);
    color: var(--index-muted);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    color: var(--index-subtle);
    background: var(--index-black);
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    transition:
      color 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      background 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card:hover .card__arrow {
    color: var(--index-white);
    background: var(--index-accent-soft);
    transform: translate3d(2px, 0, 0);
  }

  .pagination {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem 1.25rem;
    margin-top: 1.25rem;
    padding: 0.85rem 1rem;
    border-radius: 0.9rem;
    border: 1px solid var(--index-border);
    background: var(--index-dark);
  }

  .pagination__info {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    font-size: var(--sl-text-sm);
    color: var(--index-muted);
  }

  .pagination__info label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--index-subtle);
  }

  .pagination__info select {
    padding: 0.35rem 0.55rem;
    border-radius: 0.5rem;
    border: 1px solid var(--index-border);
    background: var(--index-black);
    color: var(--index-white);
    font: inherit;
    font-size: var(--sl-text-sm);
    cursor: pointer;
  }

  .pagination__nav {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .pagination__indicator {
    font-size: var(--sl-text-sm);
    color: var(--index-muted);
    white-space: nowrap;
  }

  .page-btn {
    padding: 0.45rem 0.85rem;
    border-radius: 0.55rem;
    border: 1px solid var(--index-border);
    background: var(--index-black);
    color: var(--index-white);
    font: inherit;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      opacity 0.2s ease;
  }

  .page-btn:hover:not(:disabled) {
    border-color: color-mix(in srgb, var(--index-accent) 50%, var(--index-border));
    background: var(--index-accent-soft);
  }

  .page-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .empty {
    position: relative;
    margin-top: 0.5rem;
    padding: 2.5rem 1.5rem;
    text-align: center;
    border-radius: 1rem;
    border: 1px dashed var(--index-border);
    background: var(--index-dark);
    overflow: hidden;
  }

  .empty--search {
    margin-top: 1rem;
  }

  .empty__pulse {
    display: block;
    width: 2.5rem;
    height: 2.5rem;
    margin: 0 auto 1rem;
    border-radius: 50%;
    border: 1px solid var(--index-border);
    background: radial-gradient(
      circle at center,
      var(--index-accent-muted) 0%,
      transparent 70%
    );
    animation: index-pulse 2.4s ease-in-out infinite;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
  }

  .empty__title {
    margin: 0 0 0.35rem;
    font-size: var(--sl-text-h5);
    font-weight: 600;
    color: var(--index-white);
  }

  .empty__desc {
    margin: 0;
    font-size: var(--sl-text-sm);
    color: var(--index-muted);
  }

  @keyframes index-pulse {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
      opacity: 0.65;
    }
    50% {
      transform: translate3d(0, 0, 0) scale(1.08);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .toolbar__row {
      flex-direction: column;
      align-items: stretch;
    }

    .search {
      max-width: none;
      margin-left: 0;
    }

    .search__kbd {
      display: none;
    }

    .card {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
    }

    .card__arrow {
      grid-column: 2;
      justify-self: end;
      margin-top: -1.75rem;
    }

    .pagination {
      flex-direction: column;
      align-items: stretch;
    }

    .pagination__nav {
      justify-content: space-between;
    }
  }
</style>
